# SASKI Shadow — FULL_PIPELINE test environment
# Copy this file to .env and fill in your keys.
# Never commit .env — it is gitignored.

ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Provider to use for FULL_PIPELINE tests (anthropic or openai)
SASKI_TEST_PROVIDER=anthropic

# Set to 1 to enable FULL_PIPELINE tests (requires API keys above)
SASKI_RUN_LIVE_TESTS=0
