__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.venv/
.pytest_cache/
.coverage
.mypy_cache/
.ruff_cache/
.DS_Store

# Editor backups and packed-repo / audit dumps (keep internals out of the tree)
# Match both plain ".bak" files and timestamped backups (e.g. report.py.bak.20260624_135223).
# Prune local copies older than 14 days with: find . -name '*.bak.*' ... (maintainer hygiene).
*.bak
*.bak.*
*_audit.txt
repomix-output*

# Integrator runtime turn stores (hash-only payloads, not source)
*.jsonl

# Never commit real or example env files
.env
.env.example
saski_shadow_config.json

# Session runner output (turn stores, logs, generated reports)
outputs/
# Internal-only findings file (LLM replies + dev notes). Already under outputs/,
# but listed explicitly so it is never committed even if outdir changes.
internal_findings.log
# Integrator-supplied token-savings pricing inputs. Use pricing.example.json as
# a template; the real pricing.json stays local and is never committed.
pricing.json

# Maintainer-only dev artifacts (never ship to the public repo)
scripts/run_session.py
scripts/generate_report.py
scripts/_session_common.py
scripts/Session_Tests/
scripts/sample_prompts.json
scripts/test_output_review_positive.py
