__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.venv/
.pytest_cache/
.coverage
.mypy_cache/
.ruff_cache/
.DS_Store

# Editor backups and packed-repo / audit dumps (keep internals out of the tree)
# Match both plain ".bak" files and timestamped backups produced by the
# AGENTS.md convention (e.g. report.py.bak.20260624_135223).
*.bak
*.bak.*
*_audit.txt
repomix-output*

# Integrator runtime turn stores (hash-only payloads, not source)
*.jsonl

# Never commit real or example env files
.env
.env.example
saski_shadow_config.json

# Session runner output (turn stores, logs, generated reports)
outputs/
